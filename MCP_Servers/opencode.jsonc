{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cisco_ssh": {
      "type": "local",
      "command": ["./.venv/bin/python", "cisco_ssh_mcp.py"],
      "enabled": true
    },
    "cisco_web": {
      "type": "local",
      "command": ["./.venv/bin/python", "cisco_web_mcp.py"],
      "enabled": true
    }
  }
}
